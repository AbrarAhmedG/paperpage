NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Vision AI provider. Leave AI_PROVIDER unset (default) for the free OpenAI-
# compatible path; set AI_PROVIDER=anthropic for Claude (best fidelity, paid).
# AI_PROVIDER=anthropic

# --- Default (free): Groq, OpenAI-compatible. Get a key at https://console.groq.com/keys
AI_API_KEY=your-groq-api-key
# Optional overrides (defaults shown):
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
#
# Other OpenAI-compatible providers (same code, just change these):
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1   AI_MODEL=<a free vision model>
#   Local Ollama: AI_BASE_URL=http://localhost:11434/v1    AI_MODEL=llama3.2-vision   AI_API_KEY=ollama

# --- Paid: Claude (much higher wireframe fidelity). Requires an Anthropic API
#     key (console.anthropic.com — pay-as-you-go; this is NOT a claude.ai
#     subscription). Set AI_PROVIDER=anthropic above, then:
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-opus-4-8    # default; cheaper strong-vision options: claude-sonnet-5, claude-haiku-4-5
